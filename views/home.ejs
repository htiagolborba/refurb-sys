<%# DGS - Device Grading System Created by Hiran Tiago Lins Borba Oct 2025 - Mar 2026 License: This project is open
  source. Contributions and suggestions are (always) welcome. %>
  <!DOCTYPE html>
  <html lang="en" data-theme="winter">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Device Grading</title>
    <link rel="stylesheet" href="/css/main.css">
  </head>

  <body>
    <%- include('partials/navbar') %>

      <div class="container mx-auto px-4 py-12 max-w-6xl">
        <div class="flex flex-col lg:flex-row gap-12 items-center mb-16">
          <div class="lg:w-1/2 text-center lg:text-left">
            <h1 class="text-5xl lg:text-6xl font-black tracking-tight mb-6">
              Streamlined <span class="text-primary">Device Grading System</span>
            </h1>
            <p class="text-xl opacity-80 mb-8 leading-relaxed" style="text-align: justify;">
              The centralized solution for modern refurbishing teams. Eliminate spreadsheets, automate configurations,
              and
              focus on production speed.
            </p>

            <% if (session && session.user) { %>
              <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
                <a href="/grades/new" class="btn btn-primary btn-lg rounded-xl shadow-lg hover:shadow-primary/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                  Start New Grade
                </a>
                <a href="/grades" class="btn btn-outline btn-lg rounded-xl">
                  History
                </a>
              </div>
              <% } else { %>
                <div class="flex justify-center lg:justify-start">
                  <a href="/login" class="btn btn-primary btn-lg rounded-xl px-12">Get Started</a>
                </div>
                <% } %>
          </div>

          <div class="lg:w-1/2 relative">
            <div class="bg-primary/5 rounded-3xl p-8 border border-primary/10 shadow-2xl backdrop-blur-sm">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-error"></div>
                <div class="w-3 h-3 rounded-full bg-warning"></div>
                <div class="w-3 h-3 rounded-full bg-success"></div>
              </div>
              <div class="rounded-xl overflow-hidden border border-base-200 shadow-inner" style="background:#000;">
                <video 
                  src="/video/demo.mp4" 
                  autoplay 
                  loop 
                  muted 
                  playsinline 
                  preload="metadata" 
                  style="width:100%; display:block; object-fit:cover;"
                ></video>
              </div>
            </div>
            <!-- Decorative elements -->
            <div class="absolute -top-6 -right-6 w-24 h-24 bg-primary/10 rounded-full blur-2xl"></div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
          <div class="card bg-white border border-base-200 shadow-sm hover:shadow-md transition-shadow">
            <div class="card-body">
              <div class="w-12 h-12 bg-primary/10 text-primary flex items-center justify-center rounded-xl mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="card-title">Preset-First Workflow</h3>
              <p class="opacity-70" style="text-align: justify;">Avoid repetitive typing. Select a model and all hardware specifications auto-fill
                instantly.</p>
            </div>
          </div>

          <div class="card bg-white border border-base-200 shadow-sm hover:shadow-md transition-shadow">
            <div class="card-body">
              <div class="w-12 h-12 bg-secondary/10 text-secondary flex items-center justify-center rounded-xl mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="card-title">Data Integrity</h3>
              <p class="opacity-70" style="text-align: justify;">Mandatory battery health and serial number tracking ensure your inventory is always
                accurate.</p>
            </div>
          </div>

          <div class="card bg-white border border-base-200 shadow-sm hover:shadow-md transition-shadow">
            <div class="card-body">
              <div class="w-12 h-12 bg-accent/10 text-accent flex items-center justify-center rounded-xl mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <h3 class="card-title">Team Management</h3>
              <p class="opacity-70" style="text-align: justify;">Role-based access ensures technicians can focus on grading while admins manage
                configurations.</p>
            </div>
          </div>
        </div>
      </div>
  </body>

  </html>