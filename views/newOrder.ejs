    source. Contributions and suggestions are (always) welcome. %>
    <!DOCTYPE html>
    <html lang="en" data-theme="winter">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>New Order - LGS System</title>
        <link rel="stylesheet" href="/css/main.css">
    </head>

    <body class="bg-base-200 min-h-screen pb-12">
        <%- include('partials/navbar') %>

            <div class="container mx-auto px-4 max-w-4xl mt-8">
                <div class="mb-8 flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-extrabold text-base-content tracking-tight">Create New Order</h1>
                        <p class="text-base-content/60 mt-1">Start a new grading session by defining the order details.
                        </p>
                    </div>
                </div>

                <% if (errorMessage) { %>
                    <div class="alert alert-error mb-6 shadow-sm rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>
                            <%= errorMessage %>
                        </span>
                    </div>
                    <% } %>

                        <div class="card bg-base-100 shadow-xl rounded-2xl border border-base-200 overflow-hidden">
                            <div class="card-body p-8">
                                <form action="/orders/new" method="POST" class="space-y-6">
                                    <div class="alert bg-blue-50 text-blue-800 border-blue-200 rounded-xl text-sm mb-6">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            class="stroke-current shrink-0 w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        <span>Provide a Name or an Order ID. At least one field is required.</span>
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div class="form-control w-full">
                                            <label class="label font-medium pb-1"><span class="label-text">Order
                                                    Name</span></label>
                                            <input type="text" name="name" value="<%= form.name || '' %>"
                                                placeholder="e.g. Batch Q3 Return"
                                                class="input input-bordered w-full rounded-xl focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                                                autofocus>
                                        </div>

                                        <div class="form-control w-full">
                                            <label class="label font-medium pb-1"><span class="label-text">Order
                                                    ID</span></label>
                                            <input type="text" name="orderId" value="<%= form.orderId || '' %>"
                                                placeholder="e.g. ORD-12345"
                                                class="input input-bordered w-full rounded-xl focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all">
                                        </div>
                                    </div>

                                    <div class="divider my-2"></div>

                                    <div class="form-control mt-4">
                                        <button type="submit"
                                            class="btn btn-primary w-full sm:w-auto sm:ml-auto rounded-xl shadow-md hover:shadow-lg transition-all px-8">
                                            Create & Start Grading
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none"
                                                viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                            </svg>
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
            </div>
    </body>

    </html>