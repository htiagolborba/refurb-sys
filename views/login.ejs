  source. Contributions and suggestions are (always) welcome. %>
  <!DOCTYPE html>
  <html lang="en" data-theme="winter">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - LGS System</title>
    <link rel="stylesheet" href="/css/main.css">
  </head>

  <body class="bg-base-200 min-h-screen">
    <%- include('partials/navbar') %>

      <div class="container mx-auto px-4 py-16">
        <div class="max-w-md mx-auto">
          <div class="text-center mb-10">
            <h1 class="text-4xl font-black tracking-tight mb-2">Access Granted</h1>
            <p class="opacity-60 text-lg">Enter your credentials to manage laptop grading</p>
          </div>

          <div class="card bg-white border border-base-200 shadow-2xl rounded-3xl overflow-hidden">
            <div class="card-body p-8 sm:p-10">
              <% if (errorMessage) { %>
                <div class="alert alert-error mb-6 rounded-xl text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>
                    <%= errorMessage %>
                  </span>
                </div>
                <% } %>

                  <form action="/login" method="POST">
                    <div class="form-control mb-4">
                      <label class="label">
                        <span class="label-text font-bold">User Name</span>
                      </label>
                      <div class="relative">
                        <input type="text" name="userName" placeholder="e.g. jdoe_tech" required
                          class="input input-bordered w-full pl-10 focus:input-primary" value="<%= userName %>" />
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none opacity-40">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                          </svg>
                        </div>
                      </div>
                    </div>

                    <div class="form-control mb-8">
                      <label class="label">
                        <span class="label-text font-bold">Password</span>
                      </label>
                      <div class="relative">
                        <input type="password" name="password" placeholder="••••••••" required
                          class="input input-bordered w-full pl-10 focus:input-primary" />
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none opacity-40">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                          </svg>
                        </div>
                      </div>
                    </div>

                    <button type="submit"
                      class="btn btn-primary btn-block btn-lg rounded-xl shadow-lg shadow-primary/20">
                      Sign In to Dashboard
                    </button>
                  </form>
            </div>
            <div class="bg-base-100 p-6 text-center border-t border-base-200">
              <p class="text-xs opacity-50 uppercase tracking-widest font-bold">Laptop Grading System v1.0</p>
            </div>
          </div>
        </div>
      </div>
  </body>

  </html>