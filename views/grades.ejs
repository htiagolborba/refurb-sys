<%# LGS - Laptop Grading System Created by Hiran Tiago Lins Borba Oct 2025 - Mar 2026 License: This project is open
  source. Contributions and suggestions are (always) welcome. %>
  <!DOCTYPE html>
  <html lang="en" data-theme="winter">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grades - LGS System</title>
    <link rel="stylesheet" href="/css/main.css">
  </head>

  <body class="bg-base-100 min-h-screen">
    <%- include('partials/navbar') %>

      <div class="container mx-auto px-4 py-8 max-w-7xl">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-8">
          <div>
            <h1 class="text-3xl font-black tracking-tight">Grading History</h1>
            <p class="opacity-60 text-sm">Review recently processed units and inspection details</p>
          </div>
          <a href="/grades/new" class="btn btn-primary rounded-xl shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"
              stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Grade Entry
          </a>
        </div>


        <div class="card bg-white border border-base-200 shadow-sm mb-10 overflow-visible">
          <div class="card-body p-6">
            <div class="flex items-center gap-2 mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-40" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
              </svg>
              <h2 class="font-bold text-sm uppercase tracking-widest opacity-60">Advanced Search & Filters</h2>
            </div>

            <form method="GET" action="/grades" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-4">
              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Order Name/ID</span></label>
                <select name="orderIdFilter" class="select select-bordered select-sm">
                  <option value="">All Orders</option>
                  <% orders.forEach(o=> { %>
                    <option value="<%= o.id %>" <%=(String(filters.orderIdFilter)===String(o.id)) ? "selected" : "" %> >
                      <%= o.name ? o.name + (o.orderId ? ' (' + o.orderId + ')' : '' ) : (o.orderId || 'Order #' + o.id)
                        %>
                    </option>
                    <% }); %>
                </select>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-bold">Serial Number</span></label>
                <input type="text" name="serialQuery" class="input input-bordered input-sm"
                  placeholder="Search serial..." value="<%= filters.serialQuery %>" />
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Technician</span></label>
                <select name="technician" class="select select-bordered select-sm">
                  <option value="">All Personnel</option>
                  <% users.forEach(u=> { %>
                    <option value="<%= u.userName %>" <%=(filters.technician===u.userName) ? "selected" : "" %> >
                      <%= u.userName %>
                    </option>
                    <% }); %>
                </select>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Model Preset</span></label>
                <select name="presetId" class="select select-bordered select-sm">
                  <option value="">All Models</option>
                  <% presets.forEach(p=> { %>
                    <option value="<%= p.id %>" <%=(String(filters.presetId)===String(p.id)) ? "selected" : "" %> >
                      <%= p.brand %>
                        <%= p.model %>
                    </option>
                    <% }); %>
                </select>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">From Date</span></label>
                <input type="date" name="fromDate" class="input input-bordered input-sm"
                  value="<%= filters.fromDate %>" />
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">To Date</span></label>
                <input type="date" name="toDate" class="input input-bordered input-sm" value="<%= filters.toDate %>" />
              </div>

              <div class="flex items-end gap-2 shrink-0 lg:col-span-1">
                <button class="btn btn-sm btn-primary px-4 rounded-lg" type="submit">Find</button>
                <a class="btn btn-sm btn-ghost rounded-lg" href="/grades">Reset</a>
              </div>
            </form>

            <% if (session && session.user && (session.user.role==='ADMIN' || session.user.canDeleteOrder)) { %>
              <div class="flex justify-end mt-4 pt-4 border-t border-base-200">
                <button class="btn btn-sm border-none text-white rounded-lg px-6" style="background-color:#7f1d1d;"
                  onmouseover="this.style.backgroundColor='#6b1919'" onmouseout="this.style.backgroundColor='#7f1d1d'"
                  onclick="document.getElementById('delete-order-modal').showModal()">
                  Delete entire order
                </button>
              </div>

              <dialog id="delete-order-modal" class="modal">
                <div class="modal-box text-left max-w-sm">
                  <h3 class="font-bold text-lg text-error mb-4">Delete Entire Order</h3>
                  <p class="text-sm opacity-70 mb-4">Are you sure you want to delete an entire order and ALL of its
                    recorded units? This action cannot be undone.</p>
                  <form id="deleteOrderForm" action="" method="POST" class="space-y-4">
                    <div class="form-control">
                      <label class="label"><span class="label-text font-bold">Select Order to Delete</span></label>
                      <select id="deleteOrderId" required class="select select-bordered w-full">
                        <option value="" disabled selected>Select an order...</option>
                        <% orders.forEach(o=> { %>
                          <option value="<%= o.id %>">
                            <%= o.name ? o.name + (o.orderId ? ' (' + o.orderId + ')' : '' ) : (o.orderId || 'Order #' +
                              o.id) %>
                          </option>
                          <% }); %>
                      </select>
                    </div>
                    <div class="form-control">
                      <label class="label"><span class="label-text font-bold">Username</span></label>
                      <input type="text" name="adminUsername" class="input input-bordered w-full" required
                        autocomplete="off" placeholder="Enter authorized username">
                    </div>
                    <div class="form-control">
                      <label class="label"><span class="label-text font-bold">Password</span></label>
                      <input type="password" name="adminPassword" class="input input-bordered w-full" required
                        placeholder="Enter password to confirm">
                    </div>
                    <div class="modal-action mt-6">
                      <button type="button" class="btn btn-ghost"
                        onclick="document.getElementById('delete-order-modal').close()">Cancel</button>
                      <button type="submit" class="btn btn-error text-white"
                        onclick="document.getElementById('deleteOrderForm').action = '/orders/delete/' + document.getElementById('deleteOrderId').value">Delete
                        Order</button>
                    </div>
                  </form>
                </div>
                <form method="dialog" class="modal-backdrop">
                  <button>close</button>
                </form>
              </dialog>
              <% } %>
          </div>
        </div>

        <% const hasFilters=filters.technician || filters.fromDate || filters.toDate || filters.presetId ||
          filters.orderIdFilter || filters.serialQuery; if (hasFilters) { if (grades && grades.length> 0) {
          const q = new URLSearchParams(filters).toString();
          %>

          <div class="flex justify-between items-center mt-6 mb-4">
            <h2 class="text-xl font-bold">Search Results</h2>
            <div class="flex gap-2">
              <a href="/grades/export/csv?<%= q %>" class="btn btn-sm btn-outline btn-neutral">Export CSV</a>
              <a href="/grades/export/xlsx?<%= q %>" class="btn btn-sm btn-outline btn-success">Export Excel</a>
            </div>
          </div>

          <div class="card bg-white border border-base-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="table table-zebra w-full table-md">
                <thead class="bg-base-50 border-b border-base-200">
                  <tr class="text-xs uppercase tracking-tighter opacity-70">
                    <th>Order</th>
                    <th class="w-12 text-center">#</th>
                    <th>Date</th>
                    <th>Serial Number</th>
                    <th>Configuration</th>
                    <th>Battery</th>
                    <th>Keyboard</th>
                    <th>Technician</th>
                    <th class="text-center">Touchscreen</th>
                    <th>Observations</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% function getBadgeColor(name) { let hash=0; for (let i=0; i < name.length; i++)
                    hash=name.charCodeAt(i) + ((hash << 5) - hash); const colors=['badge-primary', 'badge-secondary'
                    , 'badge-accent' , 'badge-info' , 'badge-success' , 'badge-warning' , 'badge-error' ]; return
                    colors[Math.abs(hash) % colors.length]; } grades.forEach((g, index)=> {
                    %>
                    <tr class="hover group">
                      <td class="text-xs font-bold opacity-70">
                        <% if (g.Order) { %>
                          <%= g.Order.name || g.Order.orderId %>
                            <% } else { %>
                              <span class="opacity-50">-</span>
                              <% } %>
                      </td>
                      <td class="font-bold text-center opacity-50 bg-base-200/50 rounded-lg">
                        <%= grades.length - index %>
                      </td>
                      <td class="text-sm opacity-60">
                        <div class="flex flex-col">
                          <span>
                            <%= new Date(g.createdAt).toLocaleDateString() %>
                          </span>
                          <span class="text-[10px] font-mono">
                            <%= new Date(g.createdAt).toLocaleTimeString([], {hour: '2-digit' , minute:'2-digit'}) %>
                          </span>
                        </div>
                      </td>
                      <td>
                        <span class="font-mono font-bold bg-base-200 px-2 py-1 rounded text-sm tracking-widest">
                          <%= g.serialNumber %>
                        </span>
                      </td>
                      <td class="max-w-xs">
                        <div class="flex flex-col">
                          <span class="font-bold text-sm">
                            <% if (g.ModelPreset) { %>
                              <%= g.ModelPreset.brand %>
                                <%= g.ModelPreset.model %>
                                  <% } else { %>
                                    Manual Entry
                                    <% } %>
                          </span>
                          <span class="text-[11px] opacity-60">
                            <%= g.cpu %> / <%= g.ramGb %>GB / <%= g.ssdGb %>GB
                          </span>
                        </div>
                      </td>
                      <td>
                        <% if (g.batteryHealthPercent===-1) { %>
                          <div class="badge badge-error badge-outline badge-xs opacity-70 font-bold" title="No Battery">
                            ✕
                          </div>
                          <% } else { %>
                            <% let color="text-error" ; if (g.batteryHealthPercent>= 80) color = "text-success";
                              else if (g.batteryHealthPercent >= 60) color = "text-warning";
                              %>
                              <div class="flex items-center gap-2">
                                <div class="radial-progress <%= color %>"
                                  style="--value:<%= g.batteryHealthPercent %>; --size:1.8rem; --thickness: 2px;"
                                  role="progressbar">
                                  <span class="text-[10px] font-bold text-base-content">
                                    <%= g.batteryHealthPercent %>
                                  </span>
                                </div>
                              </div>
                              <% } %>
                      </td>
                      <td class="text-xs opacity-80 font-semibold text-accent">
                        <%= g.keyboardLayout || 'English' %>
                      </td>
                      <td>
                        <div
                          class="badge <%= getBadgeColor(g.User ? g.User.userName : '-') %> badge-outline badge-sm opacity-80 font-bold tracking-wide">
                          <%= g.User ? g.User.userName : "-" %>
                        </div>
                      </td>
                      <td class="text-center font-bold text-xs tracking-wider">
                        <% if (g.touchStatus==='WORKING' ) { %>
                          <span class="text-success">GOOD</span>
                          <% } else if (g.touchStatus==='BAD' ) { %>
                            <span class="text-error">BAD</span>
                            <% } else { %>
                              <span class="text-neutral opacity-60">NO</span>
                              <% } %>
                      </td>
                      <td>
                        <div class="max-w-[200px] overflow-x-auto whitespace-nowrap scrollbar-hide text-xs opacity-70">
                          <%= g.notes || '' %>
                        </div>
                      </td>
                      <td>
                        <div class="flex gap-2">
                          <button class="btn btn-primary btn-xs text-white"
                            onclick="document.getElementById('edit-grade-<%= g.id %>').showModal()">Edit</button>
                          <form action="/grades/delete/<%= g.id %>" method="POST"
                            onsubmit="return confirm('Delete this grading entry?');">
                            <button class="btn btn-error btn-xs text-white" type="submit">Delete</button>
                          </form>
                        </div>

                        <!-- Edit Grade Modal -->
                        <dialog id="edit-grade-<%= g.id %>" class="modal">
                          <div class="modal-box max-w-2xl">
                            <h3 class="font-bold text-lg mb-4">Edit Grading Entry: <%= g.serialNumber %>
                            </h3>
                            <form action="/grades/edit/<%= g.id %>" method="POST" class="grid grid-cols-2 gap-4">
                              <div class="form-control">
                                <label class="label"><span class="label-text">Serial Number</span></label>
                                <input type="text" name="serialNumber" value="<%= g.serialNumber %>"
                                  class="input input-bordered" required>
                              </div>
                              <div class="form-control">
                                <label class="label"><span class="label-text">CPU</span></label>
                                <input type="text" name="cpu" value="<%= g.cpu %>" class="input input-bordered"
                                  required>
                              </div>
                              <div class="form-control">
                                <label class="label"><span class="label-text">RAM (GB)</span></label>
                                <input type="number" name="ramGb" value="<%= g.ramGb %>" class="input input-bordered"
                                  required>
                              </div>
                              <div class="form-control">
                                <label class="label"><span class="label-text">SSD (GB)</span></label>
                                <input type="number" name="ssdGb" value="<%= g.ssdGb %>" class="input input-bordered">
                              </div>
                              <div class="form-control">
                                <label class="label"><span class="label-text">Battery Health %</span></label>
                                <input type="number" id="editHistoryBattery-<%= g.id %>" name="batteryHealthPercent"
                                  value="<%= g.batteryHealthPercent !== -1 ? g.batteryHealthPercent : '' %>"
                                  class="input input-bordered" <%=g.batteryHealthPercent===-1 ? 'disabled' : 'required'
                                  %>
                                min="0" max="100">
                                <label class="cursor-pointer label justify-start gap-2 mt-2">
                                  <input type="checkbox" name="noBattery" class="checkbox checkbox-sm checkbox-error"
                                    <%=g.batteryHealthPercent===-1 ? 'checked' : '' %>
                                  onchange="const el = document.getElementById('editHistoryBattery-<%= g.id %>');
                                    if(this.checked) { el.disabled = true; el.value = ''; el.required = false; } else {
                                    el.disabled = false; el.required = true; }" />
                                    <span class="label-text">No Battery</span>
                                </label>
                              </div>
                              <div class="form-control col-span-2">
                                <label class="label"><span class="label-text font-bold">Touchscreen
                                    Status</span></label>
                                <div class="flex gap-4 pl-2 border border-base-200 rounded-lg p-3">
                                  <label class="label cursor-pointer justify-start gap-2">
                                    <input type="checkbox" id="touch_working_<%= g.id %>" name="touchscreen"
                                      class="checkbox checkbox-success checkbox-sm" <%=(g.touchStatus==='WORKING' )
                                      ? 'checked' : '' %> onclick="['touch_bad_<%= g.id %>', 'touch_no_<%= g.id %>
                                        '].forEach(id => document.getElementById(id).checked = false)" />
                                        <span class="label-text">Enable Touch</span>
                                  </label>
                                  <label class="label cursor-pointer justify-start gap-2">
                                    <input type="checkbox" id="touch_bad_<%= g.id %>" name="touchscreenBad"
                                      class="checkbox checkbox-error checkbox-sm" <%=(g.touchStatus==='BAD' )
                                      ? 'checked' : '' %> onclick="['touch_working_<%= g.id %>', 'touch_no_<%= g.id %>
                                        '].forEach(id =>
                                        document.getElementById(id).checked = false)" />
                                        <span class="label-text">Bad Touch</span>
                                  </label>
                                  <label class="label cursor-pointer justify-start gap-2">
                                    <input type="checkbox" id="touch_no_<%= g.id %>" name="noTouchscreen"
                                      class="checkbox checkbox-neutral checkbox-sm" <%=(g.touchStatus==='NONE' )
                                      ? 'checked' : '' %> onclick="['touch_working_<%= g.id %>', 'touch_bad_<%= g.id %>
                                        '].forEach(id => document.getElementById(id).checked = false)" />
                                        <span class="label-text">No Touch</span>
                                  </label>
                                </div>
                              </div>
                              <div class="form-control col-span-2">
                                <label class="label"><span class="label-text font-bold">Keyboard Layout</span></label>
                                <div class="pl-2 border border-base-200 rounded-lg p-3">
                                  <label class="label cursor-pointer justify-start gap-3">
                                    <input type="checkbox" name="frenchKeyboard"
                                      class="checkbox checkbox-primary checkbox-sm" <%=(g.keyboardLayout==='French' )
                                      ? 'checked' : '' %> />
                                    <span class="label-text">French Keyboard</span>
                                  </label>
                                </div>
                              </div>
                              <div class="form-control col-span-2">
                                <label class="label"><span class="label-text">Notes</span></label>
                                <textarea name="notes" class="textarea textarea-bordered h-24"><%= g.notes %></textarea>
                              </div>
                              <div class="modal-action col-span-2">
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                                <button type="button" onclick="this.closest('dialog').close()"
                                  class="btn">Cancel</button>
                              </div>
                            </form>
                          </div>
                        </dialog>
                      </td>
                    </tr>
                    <% }); %>

                      <% if (!grades || grades.length===0) { %>
                        <tr>
                          <td colspan="7" class="text-center py-16">
                            <div class="flex flex-col items-center opacity-30">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                              </svg>
                              <p class="font-bold">No grading records found <%= filters.orderQuery ? 'for "' +
                                  filters.orderQuery + '"' : '' %>
                              </p>
                            </div>
                          </td>
                        </tr>
                        <% } %>
                </tbody>
              </table>
            </div>
          </div>
          <% } else { %>
            <div class="alert alert-info shadow-sm mt-8">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                class="stroke-current shrink-0 w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>No units found for the selected filters.</span>
            </div>
            <% } } else { %>
              <div class="text-center opacity-60 mt-12 py-12 border-2 border-dashed border-base-300 rounded-2xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4 opacity-50" fill="none"
                  viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <p class="text-lg">Use the filters above to search for graded units.</p>
              </div>
              <% } %>
      </div>
  </body>

  </html>